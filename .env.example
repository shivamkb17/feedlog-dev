# FeedLog environment variables
# Copy this file to `.env` and fill in the values. For production deployments,
# prefer platform-native secret management (Cloudflare `wrangler secret put`,
# Vercel env UI, Docker `-e`, Kubernetes Secret, etc.) over committing .env.

# =============================================================================
# REQUIRED — app will not start (or has no admin) without these
# =============================================================================

# Postgres connection string. Needs the `vector` extension for AI features.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/feedlog

# Session / cookie encryption secret. Generate with: openssl rand -hex 32
# Must be 32+ random characters. Never share or commit the real value.
BETTER_AUTH_SECRET=replace-me-with-a-32-char-random-string

# Comma-separated list of emails granted admin role on first sign-up. Set
# this BEFORE the first user signs up; without it, the install has no admin
# user and you cannot manage boards / posts from the dashboard.
# Example: SYSTEM_ADMIN_EMAILS=founder@example.com,ops@example.com
SYSTEM_ADMIN_EMAILS=admin@example.com

# =============================================================================
# OPTIONAL — Public URL
# =============================================================================

# The public URL where FeedLog is served. Better-auth infers this from the
# request host when unset, which works for most deploys (including Vercel).
# Set it explicitly if you host behind a proxy that rewrites the Host header.
# No trailing slash.
# BETTER_AUTH_URL=https://feedback.yourdomain.com

# =============================================================================
# OPTIONAL — S3-compatible blob storage (Docker / Node deploys only)
# =============================================================================

# Cloudflare Workers uses its R2 binding, Vercel uses Vercel Blob — neither
# needs any S3_* vars. On Docker / bare Node, set these to point uploads at
# any S3-compatible service (AWS S3, Cloudflare R2, MinIO, Alibaba OSS,
# Tencent COS, Backblaze B2, Wasabi, Qiniu, ...).
#
# Read at RUNTIME — set them on `docker run -e` / docker-compose .env / your
# orchestrator's secret store and restart the container. No rebuild needed.
#
# Required (always 3):
#   S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_BUCKET
# Plus AT LEAST ONE of:
#   S3_ENDPOINT  — required for non-AWS services (provides the host)
#   S3_REGION    — required for AWS S3; optional elsewhere (signing falls
#                  back to us-east-1)
#
# Some providers, including Alibaba OSS, may require virtual-hosted style.
# In that case set S3_BUCKET normally and use a bucket endpoint such as
# https://<bucket>.oss-cn-hangzhou.aliyuncs.com.
#
# Leave all unset to use NuxtHub's local-filesystem driver. Docker users
# should mount a volume on /app/.data to persist local uploads across
# container restarts (the bundled compose.yml does this automatically).

# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=feedlog
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# S3_REGION=oss-cn-hangzhou

# Object key prefix for uploads (default: "uploads"). Read at runtime.
# UPLOAD_PREFIX is server-only; NUXT_PUBLIC_UPLOAD_PREFIX is kept for
# deploys that already use Nuxt's public runtime env naming.
# UPLOAD_PREFIX=uploads
# NUXT_PUBLIC_UPLOAD_PREFIX=uploads

# =============================================================================
# OPTIONAL — Sign-in methods
# =============================================================================

# OAuth providers — each pair is independent; configure one, both, or neither.
# If neither OAuth provider is configured, email+password login is auto-enabled
# so a fresh install is never locked out.
#
# Google — https://console.cloud.google.com/apis/credentials
#   Add `<your-url>/api/auth/callback/google` to the OAuth app's authorized URIs.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
#   Add `<your-url>/api/auth/callback/github` to the OAuth app's callback URL.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email + password login — explicit override.
#   unset (default): enabled iff no OAuth is configured
#   true:            force-enable (add email login alongside OAuth)
#   false:           force-disable (OAuth-only; DO NOT use if no OAuth set)
# AUTH_EMAIL_ENABLED=

# Require users to verify their email before sign-in.
#   unset (default): on iff a real email provider is configured (RESEND_API_KEY)
#   true/false:      force override. Setting true without an email provider
#                    breaks signup (verification email can't be sent).
# AUTH_EMAIL_VERIFY=

# =============================================================================
# OPTIONAL — AI features (similar-idea merge, AI-drafted changelog)
# =============================================================================

# Any OpenAI-compatible API works: OpenAI, Azure OpenAI, LiteLLM proxy,
# Ollama, etc. Leave unset to disable AI features.

# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TEXT_MODEL=gpt-5.4

# =============================================================================
# OPTIONAL — Transactional email (password reset, notifications)
# =============================================================================

# Provider identifier. Currently supported: "resend". Leave unset to use
# the console-logging fallback (development only).
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com
